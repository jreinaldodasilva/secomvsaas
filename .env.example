# Required — URL of the backend API (e.g. http://localhost:5000)
VITE_API_URL=http://localhost:5000

# Optional — deployment environment (development | staging | production). Defaults to 'development'.
VITE_APP_ENV=development

# Environment-specific templates (committed, not secret-bearing):
#   .env.staging    — staging build reference  (vite build --mode staging)
#   .env.production — production build reference (vite build / vite build --mode production)
#
# To override locally without committing, create .env.staging.local or .env.production.local.
