# ================================
# SECOM FRONTEND — STAGING CONFIG
# ================================
# Loaded automatically by Vite when building with --mode staging:
#   vite build --mode staging
#
# For local overrides (never commit), create .env.staging.local.
# All <placeholder> values must be replaced before deploying.

# Required — staging backend API URL
VITE_API_URL=https://api.staging.secom.gov.br

# Deployment environment — must be 'staging'
VITE_APP_ENV=staging
