# ===========================
# SECOM PIQUETE — BACKEND CONFIGURATION
# ===========================

NODE_ENV=development
PORT=5000

# Database
# For local development with Docker Compose: mongodb://localhost:27017/secom?replicaSet=rs0
# For production replica set: mongodb://host1:27017,host2:27017,host3:27017/secom?replicaSet=rs0&authSource=admin
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/secom
DATABASE_URL=mongodb://localhost:27017/secom?replicaSet=rs0

# Redis
# Standalone (default)
REDIS_URL=redis://localhost:6379
# Redis Sentinel — set REDIS_SENTINEL_HOSTS to activate Sentinel mode
# REDIS_SENTINEL_HOSTS=sentinel1:26379,sentinel2:26379,sentinel3:26379
# REDIS_SENTINEL_NAME=mymaster

# Auth — REQUIRED in all environments. Generate with: openssl rand -hex 32
# These have NO fallback values — the server will refuse to start without them.
JWT_SECRET=your_jwt_secret_min_64_chars_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=your_refresh_secret_min_64_chars_generate_with_openssl_rand_hex_32
PORTAL_JWT_SECRET=your_portal_jwt_secret_min_64_chars_generate_with_openssl_rand_hex_32
# Access token expiry — canonical variable (JWT_EXPIRES_IN has been removed)
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
PORTAL_REFRESH_TOKEN_EXPIRES_DAYS=7
MAX_REFRESH_TOKENS_PER_USER=5

# CSRF — REQUIRED in all environments. Generate with: openssl rand -hex 16
# This has NO fallback value — the server will refuse to start without it.
CSRF_SECRET=your_csrf_secret_min_32_chars

# CORS
FRONTEND_URL=http://localhost:3000

# Email
FROM_EMAIL=noreply@piquete.sp.gov.br
ADMIN_EMAIL=secom@piquete.sp.gov.br
MOCK_EMAIL_SERVICE=true
ETHEREAL_USER=
ETHEREAL_PASS=
SENDGRID_API_KEY=

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=secom-piquete-files

# Logging
LOG_LEVEL=info
DETAILED_ERRORS=true

# Security
COOKIE_SECURE=false
TRUST_PROXY=0
# VERIFY_USER_ON_REQUEST — controls whether the user's active status is checked
# on every authenticated request (via a 30-second Redis cache to avoid DB hits).
# Set to true in all environments, including production.
# Only set to false in high-throughput local development where Redis is unavailable
# and the performance overhead is unacceptable. Never use false in production:
# deactivated users will retain API access until their access token expires (~15 min).
VERIFY_USER_ON_REQUEST=true

# Seed — REQUIRED in all environments. No fallback value exists.
# The server will refuse to start without this variable on first run.
DEFAULT_ADMIN_PASSWORD=

# Monitoring
SENTRY_DSN=

# Secrets backend
# Controls where application secrets are loaded from.
# 'env'          — read from environment variables (default, suitable for dev/CI)
# 'aws-ssm'      — injected via AWS SSM Parameter Store at deploy time (no code change needed)
# 'aws-secrets'  — fetched from AWS Secrets Manager at startup (requires AWS SDK + IAM role)
# In production, set this to 'aws-ssm' or 'aws-secrets' and follow the rotation runbook:
# docs/operations/SECRETS_ROTATION_RUNBOOK.md
SECRETS_BACKEND=env
