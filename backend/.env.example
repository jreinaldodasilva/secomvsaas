# ===========================
# VSAAS BACKEND CONFIGURATION
# ===========================

NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=mongodb://localhost:27017/vsaas

# Redis
REDIS_URL=redis://localhost:6379

# Auth — REQUIRED in all environments. Generate with: openssl rand -hex 32
# These have NO fallback values — the server will refuse to start without them.
JWT_SECRET=your_jwt_secret_min_64_chars_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=your_refresh_secret_min_64_chars_generate_with_openssl_rand_hex_32
PORTAL_JWT_SECRET=your_portal_jwt_secret_min_64_chars_generate_with_openssl_rand_hex_32
# Access token expiry — canonical variable (JWT_EXPIRES_IN has been removed)
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
PORTAL_REFRESH_TOKEN_EXPIRES_DAYS=7
MAX_REFRESH_TOKENS_PER_USER=5

# CSRF — REQUIRED in all environments. Generate with: openssl rand -hex 16
# This has NO fallback value — the server will refuse to start without it.
CSRF_SECRET=your_csrf_secret_min_32_chars

# CORS
FRONTEND_URL=http://localhost:3000

# Email
FROM_EMAIL=noreply@vsaas.app
ADMIN_EMAIL=admin@vsaas.app
MOCK_EMAIL_SERVICE=true
ETHEREAL_USER=
ETHEREAL_PASS=
SENDGRID_API_KEY=

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=vsaas-files

# Logging
LOG_LEVEL=info
DETAILED_ERRORS=true

# Security
COOKIE_SECURE=false
TRUST_PROXY=0
VERIFY_USER_ON_REQUEST=false

# Seed — REQUIRED in all environments. No fallback value exists.
# The server will refuse to start without this variable on first run.
DEFAULT_ADMIN_PASSWORD=

# Monitoring
SENTRY_DSN=
