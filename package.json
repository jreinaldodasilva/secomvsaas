{
  "name": "secom-frontend",
  "version": "0.1.0",
  "description": "Secom — Sistema da Secretaria de Comunicação — Frontend",
  "private": true,
  "type": "module",
  "dependencies": {
    "@tanstack/react-query": "^5.89.0",
    "@vsaas/types": "file:packages/types",
    "framer-motion": "^12.37.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^4.12.0",
    "react-router-dom": "^6.30.1",
    "zustand": "^4.5.7"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "vite",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "dev:backend": "cd backend && npm run dev",
    "server": "cd backend && npm run dev",
    "build": "tsc && vite build",
    "build:all": "npm run build && cd backend && npm run build",
    "preview": "vite preview",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "test:frontend:coverage": "vitest run --coverage",
    "test:backend": "cd backend && npm test",
    "test:all": "npm run test:frontend && npm run test:backend",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "lint": "eslint src/",
    "lint:backend": "cd backend && npm run lint",
    "lint:all": "npm run lint && npm run lint:backend",
    "lint:fix": "eslint src/ --fix",
    "type-check": "npm run type-check:frontend && npm run type-check:backend",
    "type-check:frontend": "tsc --noEmit",
    "type-check:backend": "cd backend && tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "seed:test": "cd backend && npm run seed:test",
    "seed": "cd backend && npm run seed",
    "generate-secrets": "node scripts/generate-secrets.js",
    "generate:module": "npx ts-node packages/cli/src/generate-module.ts",
    "infra:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f infrastructure/docker/docker-compose.yml down",
    "dev:docker": "docker compose -f infrastructure/docker/docker-compose.dev.yml up --build"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@tanstack/react-query-devtools": "^5.89.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.6.0",
    "@types/react": "^18.2.39",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.0.0",
    "concurrently": "^9.2.0",
    "cypress": "^15.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "lint-staged": "^16.2.3",
    "prettier": "^3.6.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^2.0.0",
    "wait-on": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.{json,md}": [
      "prettier --write"
    ]
  }
}
